FROM golang:1.24-alpine AS go-builder

WORKDIR /build

COPY go.mod ./
RUN go mod download

COPY . .
RUN mkdir -p src/internal/frontend/dist && \
    echo "<html></html>" > src/internal/frontend/dist/index.html

RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o /app/daemon ./src/cmd/daemon

FROM alpine:3.19

RUN for i in 1 2 3; do \
        apk update --no-cache && \
        apk add --no-cache --update-cache ca-certificates tzdata bash wget && \
        break || sleep 5; \
    done

WORKDIR /app

COPY --from=go-builder /app/daemon .
COPY docker/entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

RUN mkdir -p /app/data

EXPOSE 8091

ENV ENVIRONMENT=prod
ENV PORT=:8091

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["./daemon"]
